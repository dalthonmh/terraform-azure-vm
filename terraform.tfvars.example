####################
# Common Variables #
####################
company     = "kopicloud"
app_name    = "iac-test"
environment = "dev"
location    = "northeurope"

##################
# Authentication #
##################
# For local development: leave these empty and use `az login` (recommended)
# For CI/CD or automation: fill with service principal credentials
azure-tenant-id       = ""
azure-subscription-id = ""
azure-client-id       = ""
azure-client-secret   = ""

###########
# Network #
###########
network-vnet-cidr   = "10.128.0.0/16"
network-subnet-cidr = "10.128.1.0/24"

##################
# VM Information #
##################
linux_vm_size        = "Standard_B2s"
linux_admin_username = "tfadmin"
